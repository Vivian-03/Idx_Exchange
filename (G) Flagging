import pandas as pd
sold = pd.read_csv('C:/IDX EXCHANGE/Sold_combined.csv', encoding = 'latin1', low_memory=False)
sold_residential = pd.read_csv ('C:/IDX EXCHANGE/Sold_Residential.csv', encoding = 'latin1', low_memory=False)
listing = pd.read_csv ('C:/IDX EXCHANGE/Listing_combined.csv', encoding = 'latin1', low_memory=False)
listing_residential = pd.read_csv('C:/IDX EXCHANGE/Listing_Residential.csv', encoding ='latin1', low_memory=False)
#calculate missing stats
missing_counts = sold_residential.isnull().sum()
missing_percent = (missing_counts / len(sold_residential)) * 100

#create summary DataFrame
missing_summary = pd.DataFrame({
    'Column': sold_residential.columns,
    'Missing_Count': missing_counts,
    'Missing_Percent': missing_percent,
    'Flag_>90%': missing_percent > 90
    })

#filter to show only flagged columns
flagged = missing_summary[missing_summary['Flag_>90%'] == True]
print(flagged)

missing_counts = listing_residential.isnull().sum()
missing_percent = (missing_counts / len(listing_residential)) * 100

#create summary DataFrame
